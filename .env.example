# Supabase (see supabase/migrations/0001_init.sql for the schema this expects)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
anon_key=

# Anthropic (powers every LangChain/LangGraph agent under src/lib/langchain/)
ANTHROPIC_API_KEY=

# Optional: LangSmith tracing/observability for every LangChain/LangGraph call
# (Plan chat, the Orchestrator's specialists, the Insight Narrator, and the
# eval harness). Leave unset to run with tracing off — nothing else changes
# either way, no code path depends on these being present.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=wio-flow
